# Copy to .env for local dev. NEVER commit the real .env.
NODE_ENV=development
PORT=3000

# Session signing secret (any long random string)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# PHI encryption master key — MUST be exactly 64 hex characters (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: back this up securely. If lost, all encrypted patient data is unrecoverable.
PHI_ENCRYPTION_KEY=

# Where the SQLite file lives (use a persistent volume path in production)
DB_PATH=./chemocure.db

# Session lifetime in minutes
SESSION_TTL_MIN=120
