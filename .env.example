# ── ChemoCure environment variables ──────────────────────────────────
# Copy to .env for LOCAL dev. NEVER commit the real .env (it is gitignored).
# On a cloud host (Vercel / Render / Fly), set these in the host's dashboard
# — a .env file in the repo is NOT read by those platforms.

NODE_ENV=development
PORT=3000

# ── REQUIRED IN PRODUCTION (the app refuses to start without them) ────
# Session signing secret — any long random string.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# PHI encryption master key — MUST be exactly 64 hex characters (32 bytes).
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: back this up. If lost, all encrypted patient data is unrecoverable.
PHI_ENCRYPTION_KEY=

# ── DATABASE ─────────────────────────────────────────────────────────
# Local dev / persistent-disk hosts (Render, Fly, Railway): a SQLite file.
DB_PATH=./chemocure.db

# SERVERLESS hosts (Vercel, Netlify): SQLite files DO NOT work there
# (read-only, ephemeral filesystem). You MUST use Turso (libsql over HTTP).
# Create a free database at https://turso.tech, then set BOTH:
#   TURSO_DATABASE_URL=libsql://your-db-name.turso.io
#   TURSO_AUTH_TOKEN=eyJ...            (from: turso db tokens create <db>)
# When TURSO_DATABASE_URL is set it overrides DB_PATH.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── OPTIONAL ─────────────────────────────────────────────────────────
SESSION_TTL_MIN=120
REQUIRE_DOCTOR_APPROVAL=false
# Web push (optional): generate with  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
